# RegSentinel — environment variables
# Copy this file to .env and fill in your keys.

# Required
OPENAI_API_KEY=sk-...

# Optional — set to enable LangSmith tracing (Task 3)
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=RegSentinel-Capstone-v2

# Optional — override the default model
# The notebook uses gpt-5.1-mini; fall back to gpt-4o-mini if unavailable
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
