# Copy this file to .env and fill in your API keys

# Required: OpenAI API key (used by all 5 frameworks)
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Google API key (for Google ADK with native Gemini instead of LiteLLM)
# GOOGLE_API_KEY=...

# LangSmith tracing — enabled automatically when LANGCHAIN_API_KEY is set.
# Traces ALL 5 frameworks under the same project in LangSmith.
# LANGCHAIN_TRACING_V2 and LANGCHAIN_PROJECT are set automatically by main.py.
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=compare-adks
