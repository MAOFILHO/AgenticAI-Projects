# Required: OpenAI API key (used for embeddings, generator LLM, judge LLM,
# the agentic pattern, and the OpenAI File Search pattern).
OPENAI_API_KEY=sk-your-key-here

# RAGAS metrics (Faithfulness, Answer Relevancy, Context Precision, Context
# Recall) are enabled by default -- ragas + datasets are installed via
# requirements.txt. Set to false to skip these (faster, fewer LLM calls).
ENABLE_RAGAS=true

# Optional: number of questions used for LLM-as-judge / RAGAS generation metrics
# (retrieval metrics always run on the full 40-question dataset)
E2E_SAMPLE_SIZE=10

# Optional: experiment name, used in the exported Excel filename
EXPERIMENT_NAME=rag_pattern_comparison

# --- Observability (enabled by default; pipeline runs fine without these set) ---

# LangSmith tracing. If set, every LangChain-based pattern run (1-5, 7) is
# traced automatically; the pipeline prints a link to view traces. The OpenAI
# File Search pattern (6) uses the raw OpenAI SDK and is NOT traced by LangSmith.
# LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_PROJECT=rag-pattern-comparison

# Langfuse tracing. Covers ALL 7 patterns, including the raw OpenAI SDK File
# Search pattern (6) via the langfuse.openai drop-in client, plus the
# LangChain-based patterns (1-5, 7) via the Langfuse LangChain callback handler.
# LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
# LANGFUSE_SECRET_KEY=sk-lf-your-key-here
# LANGFUSE_HOST=https://cloud.langfuse.com
